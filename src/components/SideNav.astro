---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  items: { id: string; label: string }[];
}

const { items } = Astro.props;
---

<nav class="side-nav fade-in" aria-label="Page navigation">
  <div class="side-nav__inner">
    {items.map((item) => (
      <a href={`#${item.id}`} class="side-nav__link">{item.label}</a>
    ))}
    <ThemeToggle />
  </div>
</nav>

<style>
  .side-nav {
    position: relative;
    opacity: 0;
    transition: opacity 0.5s ease;
    transition-delay: 0.9s;
  }

  .side-nav.is-visible {
    opacity: 1;
  }

  .side-nav__inner {
    position: sticky;
    top: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    text-align: right;
  }

  .side-nav__link {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    min-height: var(--touch-target-compact);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.125rem 0;
    transition: color 0.2s ease;
  }

  .side-nav__link:hover {
    color: var(--color-hover);
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .side-nav {
      display: none;
    }
  }
</style>
