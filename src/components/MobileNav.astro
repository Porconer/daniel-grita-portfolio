---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  items: { id: string; label: string }[];
}

const { items } = Astro.props;
---

<nav class="mobile-nav" aria-label="Mobile navigation">
  {items.map((item) => (
    <a href={`#${item.id}`} class="mobile-nav__link">{item.label}</a>
  ))}
  <ThemeToggle />
</nav>
