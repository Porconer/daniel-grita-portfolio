---
import Layout from '../layouts/Layout.astro';
import SideNav from '../components/SideNav.astro';
import MobileNav from '../components/MobileNav.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

const colors = [
  { name: 'Background', var: '--color-bg', light: '#ffffff', dark: '#121412', hasBorder: true },
  { name: 'Title', var: '--color-title', light: '#191d1a', dark: '#f0f2f0' },
  { name: 'Text', var: '--color-text', light: '#3a3f3b', dark: '#c5c9c6' },
  { name: 'Text Secondary', var: '--color-text-secondary', light: '#6b716c', dark: '#8a8f8b' },
  { name: 'Border', var: '--color-border', light: '#e5e5e5', dark: '#2a2d2a' },
  { name: 'Hover', var: '--color-hover', light: '#000000', dark: '#ffffff' },
  { name: 'Accent', var: '--color-accent', light: '#cff500', dark: '#cff500' },
  { name: 'On Accent', var: '--color-on-accent', light: '#191d1a', dark: '#191d1a' },
];

const spacing = [
  { name: 'XS', var: '--space-xs', value: '0.5rem (8px)' },
  { name: 'SM', var: '--space-sm', value: '1rem (16px)' },
  { name: 'MD', var: '--space-md', value: '2rem (32px)' },
  { name: 'Content Gap', var: '--space-content-gap', value: '2rem (32px), gap between elements within a section' },
  { name: 'LG', var: '--space-lg', value: '4rem (64px)' },
  { name: 'XL', var: '--space-xl', value: '6rem (96px)' },
  { name: '2XL', var: '--space-2xl', value: '10rem (160px)' },
];

const layout = [
  { name: 'Max Width', var: '--max-width', value: '1000px' },
  { name: 'Nav Width', var: '--nav-width', value: '90px' },
];

const navItems = [
  { id: 'top', label: 'Top' },
  { id: 'colors', label: 'Colors' },
  { id: 'typography', label: 'Type' },
  { id: 'spacing', label: 'Spacing' },
  { id: 'layout', label: 'Layout' },
  { id: 'components', label: 'Components' },
  { id: 'states', label: 'States' },
];
---

<Layout title="Design System | Daniel Grita" noindex>
  <div id="top"></div>

  <MobileNav items={navItems} />

  <div class="page">
    <main class="main-content">
      <!-- Header -->
      <header class="ds__header fade-in">
        <h1 class="ds__title">Design System</h1>
        <p class="ds__subtitle">Daniel Grita Portfolio · Tokens, Typography & Components</p>
      </header>

      <!-- Colors -->
      <section class="ds__section" id="colors">
        <h2 class="ds__section-title animate">Colors</h2>
        <p class="ds__section-note animate">All colors adapt between light and dark themes via CSS custom properties. The accent color and on-accent stay constant across themes.</p>
        <div class="ds__colors">
          {colors.map((color) => (
            <div class="ds__color-card animate">
              <div
                class="ds__color-swatch"
                style={`background-color: var(${color.var});${color.hasBorder ? ' border: 1px solid var(--color-border);' : ''}`}
              />
              <div class="ds__color-info">
                <span class="ds__color-name">{color.name}</span>
                <code class="ds__color-var">{color.var}</code>
                <div class="ds__color-values">
                  <code class="ds__color-value" title="Light theme">{color.light}</code>
                  <code class="ds__color-value" title="Dark theme">{color.dark}</code>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Typography -->
      <section class="ds__section" id="typography">
        <h2 class="ds__section-title animate">Typography</h2>
        <p class="ds__section-note animate">Font family: <strong>Quantico</strong> · Weights: 400 (Regular), 400i (Italic), 700 (Bold), 700i (Bold Italic)</p>

        <div class="ds__type-samples">
          <div class="ds__type-row animate">
            <div class="ds__type-meta">
              <code>h1</code>
              <span>2rem / 700 / 1.1 / -0.03em</span>
            </div>
            <h1 class="ds__type-sample">Daniel Grita</h1>
          </div>

          <div class="ds__type-row animate">
            <div class="ds__type-meta">
              <code>h2</code>
              <span>0.875rem / 500 / uppercase / 0.08em</span>
            </div>
            <h2 class="ds__type-sample-h2">Section Label</h2>
          </div>

          <div class="ds__type-row animate">
            <div class="ds__type-meta">
              <code>h3</code>
              <span>1.25rem / 600 / 1.3</span>
            </div>
            <h3 class="ds__type-sample">Lead Designer</h3>
          </div>

          <div class="ds__type-row animate">
            <div class="ds__type-meta">
              <code>p (body)</code>
              <span>1rem / 400 / 1.7 / secondary color</span>
            </div>
            <p class="ds__type-sample">Portuguese Visual Artist based in Barcelona. Wrestling daily with Graphic Design, Web Design, and Creative Direction.</p>
          </div>

          <div class="ds__type-row animate">
            <div class="ds__type-meta">
              <code>.small</code>
              <span>0.8125rem / 400 / secondary color</span>
            </div>
            <span class="ds__type-sample ds__type-small">Navigation / Meta text</span>
          </div>

          <div class="ds__type-row animate">
            <div class="ds__type-meta">
              <code>a (link)</code>
              <span>underline / 3px offset / color transition</span>
            </div>
            <a href="#" class="ds__type-sample ds__type-link" onclick="return false">danielgrita@gmail.com</a>
          </div>

          <div class="ds__type-row animate">
            <div class="ds__type-meta">
              <code>.cs__caption</code>
              <span>0.875rem / italic / center / secondary color</span>
            </div>
            <p class="cs__caption ds__type-sample">Previous social media assets and website before the rebrand.</p>
          </div>
        </div>
      </section>

      <!-- Spacing -->
      <section class="ds__section" id="spacing">
        <h2 class="ds__section-title animate">Spacing Scale</h2>
        <div class="ds__spacing-list">
          {spacing.map((sp) => (
            <div class="ds__spacing-row animate">
              <div class="ds__spacing-meta">
                <strong>{sp.name}</strong>
                <code>{sp.var}</code>
                <span>{sp.value}</span>
              </div>
              <div class="ds__spacing-bar" style={`width: var(${sp.var})`} />
            </div>
          ))}
        </div>
      </section>

      <!-- Layout -->
      <section class="ds__section" id="layout">
        <h2 class="ds__section-title animate">Layout</h2>
        <div class="ds__layout-tokens">
          {layout.map((l) => (
            <div class="ds__layout-row animate">
              <strong>{l.name}</strong>
              <code>{l.var}</code>
              <span>{l.value}</span>
            </div>
          ))}
        </div>

        <p class="ds__section-note animate">Two-column grid: main content (1fr) + side nav (90px). Collapses to single column at 768px with a sticky mobile nav bar.</p>

        <div class="ds__layout-diagram animate">
          <div class="ds__layout-grid">
            <div class="ds__layout-main">
              <span>Main Content (1fr)</span>
            </div>
            <div class="ds__layout-nav">
              <span>Nav (90px)</span>
            </div>
          </div>
          <div class="ds__layout-label">max-width: 1000px</div>
        </div>
      </section>

      <!-- Components -->
      <section class="ds__section" id="components">
        <h2 class="ds__section-title animate">Components</h2>

        <!-- Section Label -->
        <div class="ds__component animate">
          <h3 class="ds__component-name">Section Label</h3>
          <div class="ds__component-preview">
            <h2 class="section__label">About</h2>
          </div>
        </div>

        <!-- Work Entry -->
        <div class="ds__component animate">
          <h3 class="ds__component-name">Work Entry</h3>
          <div class="ds__component-preview">
            <article class="work__entry">
              <span class="work__period">2024 – Present</span>
              <h3 class="work__title">Lead Designer</h3>
              <span class="work__company">PayXpert</span>
              <p class="work__description">Leading the design at PayXpert, an omnichannel payment solution based in France and Spain.</p>
            </article>
          </div>
        </div>

        <!-- Side Navigation -->
        <div class="ds__component animate">
          <h3 class="ds__component-name">Side Navigation</h3>
          <div class="ds__component-preview">
            <nav class="ds__side-nav-sample">
              <a href="#" onclick="return false">Top</a>
              <a href="#" onclick="return false" class="is-active">About</a>
              <a href="#" onclick="return false">Work</a>
              <a href="#" onclick="return false">Connect</a>
            </nav>
          </div>
        </div>

        <!-- Mobile Navigation -->
        <div class="ds__component animate">
          <h3 class="ds__component-name">Mobile Navigation</h3>
          <p class="ds__section-note">Sticky top bar shown at 768px and below. Horizontally scrollable with centered links.</p>
          <div class="ds__component-preview ds__component-preview--transparent">
            <nav class="ds__mobile-nav-sample">
              <a href="#" onclick="return false">Top</a>
              <a href="#" onclick="return false" class="is-active">About</a>
              <a href="#" onclick="return false">Work</a>
              <a href="#" onclick="return false">Projects</a>
              <a href="#" onclick="return false">Connect</a>
              <ThemeToggle />
            </nav>
          </div>
        </div>

        <!-- Cards -->
        <div class="ds__component animate">
          <h3 class="ds__component-name">Case Study Card</h3>
          <div class="ds__component-preview">
            <div class="ds__card-sample">
              <h3 class="ds__card-sample-title">Unified Visual Identity</h3>
              <p class="ds__card-sample-desc">Create a cohesive brand language across all customer-facing touchpoints.</p>
            </div>
          </div>
        </div>

        <!-- Highlight Banner -->
        <div class="ds__component animate">
          <h3 class="ds__component-name">Highlight Banner</h3>
          <div class="ds__component-preview ds__component-preview--transparent">
            <div class="ds__highlight-sample">
              <h3 class="ds__highlight-sample-title">Problem to Solve</h3>
              <p>How to unify a fragmented brand while maintaining trust with existing customers?</p>
            </div>
          </div>
        </div>

        <!-- Contact Links -->
        <div class="ds__component animate">
          <h3 class="ds__component-name">Contact Links</h3>
          <div class="ds__component-preview">
            <div class="contact__links">
              <a href="#" onclick="return false">danielgrita@gmail.com</a>
              <a href="#" onclick="return false">LinkedIn</a>
              <a href="#" onclick="return false">Instagram</a>
            </div>
          </div>
        </div>

        <!-- Theme Toggle -->
        <div class="ds__component animate">
          <h3 class="ds__component-name">Theme Toggle</h3>
          <div class="ds__component-preview">
            <button class="theme-toggle" type="button" aria-label="Toggle dark mode">
              <span class="theme-toggle__icon theme-toggle__icon--light">☀</span>
              <span class="theme-toggle__icon theme-toggle__icon--dark">☾</span>
            </button>
          </div>
        </div>
      </section>

      <!-- States -->
      <section class="ds__section" id="states">
        <h2 class="ds__section-title animate">Interactive States</h2>
        <div class="ds__states">
          <div class="ds__state-row animate">
            <span class="ds__state-label">Link · Default</span>
            <a class="ds__state-demo ds__state-link-default">danielgrita@gmail.com</a>
          </div>
          <div class="ds__state-row animate">
            <span class="ds__state-label">Link · Hover</span>
            <a class="ds__state-demo ds__state-link-hover">danielgrita@gmail.com</a>
          </div>
          <div class="ds__state-row animate">
            <span class="ds__state-label">Nav Link · Default</span>
            <a class="ds__state-demo ds__state-nav-default">About</a>
          </div>
          <div class="ds__state-row animate">
            <span class="ds__state-label">Nav Link · Active</span>
            <a class="ds__state-demo ds__state-nav-active">About</a>
          </div>
          <div class="ds__state-row animate">
            <span class="ds__state-label">Selection</span>
            <span class="ds__state-demo ds__state-selection">Selected text</span>
          </div>
        </div>
      </section>
    </main>

    <SideNav items={navItems} />
  </div>

  <a href="/" class="ds-link">&larr; Portfolio</a>
</Layout>

<style>
  /* ------------------------------------------------
     Header
     ------------------------------------------------ */

  .ds__header {
    margin-bottom: var(--space-xl);
  }

  .ds__title {
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .ds__subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
  }

  /* ------------------------------------------------
     Sections
     ------------------------------------------------ */

  .ds__section {
    margin-bottom: var(--space-2xl);
  }

  .ds__section-title {
    display: inline-block;
    font-size: 0.75rem !important;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-on-accent);
    margin-bottom: var(--space-md);
    padding: 0.25rem 0.75rem;
    background-color: var(--color-accent);
    border-radius: var(--radius-sm);
  }

  .ds__section-note {
    font-size: 0.875rem;
    margin-bottom: var(--space-md);
  }

  /* ------------------------------------------------
     Colors
     ------------------------------------------------ */

  .ds__colors {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-md);
  }

  .ds__color-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .ds__color-swatch {
    width: 100%;
    aspect-ratio: 1;
    border-radius: var(--radius-md);
  }

  .ds__color-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ds__color-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .ds__color-var {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    font-family: var(--font-sans);
  }

  .ds__color-values {
    display: flex;
    gap: var(--space-xs);
  }

  .ds__color-value {
    font-size: 0.6875rem;
    color: var(--color-text-secondary);
    font-family: var(--font-sans);
  }

  .ds__color-value:first-child::before {
    content: '☀ ';
  }

  .ds__color-value:last-child::before {
    content: '☾ ';
  }

  /* ------------------------------------------------
     Typography
     ------------------------------------------------ */

  .ds__type-samples {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .ds__type-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .ds__type-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  .ds__type-meta code {
    background: var(--color-border);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-weight: 700;
    color: var(--color-text);
  }

  .ds__type-sample-h2 {
    color: var(--color-text-secondary);
  }

  .ds__type-small {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .ds__type-link {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .ds__type-link:hover {
    color: var(--color-accent);
  }

  /* ------------------------------------------------
     Spacing
     ------------------------------------------------ */

  .ds__spacing-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .ds__spacing-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .ds__spacing-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    min-width: 320px;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .ds__spacing-meta strong {
    color: var(--color-text);
    min-width: 32px;
  }

  .ds__spacing-meta code {
    background: var(--color-border);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-size: 0.75rem;
  }

  .ds__spacing-bar {
    height: 20px;
    background-color: var(--color-text);
    border-radius: var(--radius-sm);
    min-width: 8px;
  }

  /* ------------------------------------------------
     Layout
     ------------------------------------------------ */

  .ds__layout-tokens {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    margin-bottom: var(--space-md);
    font-size: 0.8125rem;
  }

  .ds__layout-row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-text-secondary);
  }

  .ds__layout-row strong {
    color: var(--color-text);
    min-width: 100px;
  }

  .ds__layout-row code {
    background: var(--color-border);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-size: 0.75rem;
  }

  .ds__layout-diagram {
    margin-top: var(--space-md);
  }

  .ds__layout-grid {
    display: grid;
    grid-template-columns: 1fr 90px;
    gap: var(--space-sm);
    height: 120px;
  }

  .ds__layout-main,
  .ds__layout-nav {
    background: var(--color-border);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .ds__layout-label {
    text-align: center;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  /* ------------------------------------------------
     Components
     ------------------------------------------------ */

  .ds__component {
    margin-bottom: var(--space-lg);
  }

  .ds__component-name {
    font-size: 0.875rem;
    font-weight: 700;
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }

  .ds__component-preview {
    border-radius: var(--radius-md);
    padding: var(--space-md);
    background: var(--color-border);
  }

  .ds__component-preview--transparent {
    background: transparent;
    padding: 0;
  }

  /* Side nav sample */
  .ds__side-nav-sample {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    text-align: right;
    max-width: 90px;
    margin-left: auto;
  }

  .ds__side-nav-sample a {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.25rem 0;
    transition: color 0.2s ease;
  }

  .ds__side-nav-sample a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .ds__side-nav-sample a.is-active {
    font-weight: 900;
    color: var(--color-hover);
  }

  /* Mobile nav sample */
  .ds__mobile-nav-sample {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.75rem var(--space-sm);
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    border-top: 1px solid var(--color-border);
    overflow-x: auto;
  }

  .ds__mobile-nav-sample a {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s ease;
  }

  .ds__mobile-nav-sample a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .ds__mobile-nav-sample a.is-active {
    font-weight: 900;
    color: var(--color-hover);
  }

  /* Work entry sample */
  .work__entry {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .work__period {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  .work__title {
    font-size: 1.25rem;
    font-weight: 600;
  }

  .work__company {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }

  .work__description {
    margin-top: var(--space-xs);
  }

  /* Card sample */
  .ds__card-sample {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    max-width: 320px;
    background: var(--color-bg);
  }

  .ds__card-sample-title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-title);
    margin-bottom: var(--space-xs);
  }

  .ds__card-sample-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  /* Highlight sample */
  .ds__highlight-sample {
    padding: var(--space-md);
    background-color: var(--color-accent);
    border-radius: var(--radius-md);
  }

  .ds__highlight-sample-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-on-accent);
    margin-bottom: var(--space-xs);
  }

  .ds__highlight-sample p {
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.6;
    color: var(--color-on-accent);
  }

  /* ------------------------------------------------
     States
     ------------------------------------------------ */

  .ds__states {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .ds__state-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .ds__state-label {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    min-width: 160px;
  }

  .ds__state-demo {
    font-family: var(--font-sans);
    pointer-events: none;
  }

  .ds__state-link-default {
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-size: 0.9375rem;
  }

  .ds__state-link-hover {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-size: 0.9375rem;
  }

  .ds__state-nav-default {
    color: var(--color-text-secondary);
    font-size: 0.8125rem;
  }

  .ds__state-nav-active {
    color: var(--color-hover);
    font-size: 0.8125rem;
    font-weight: 900;
  }

  .ds__state-selection {
    background: var(--color-text);
    color: var(--color-bg);
    padding: 2px 6px;
  }

  /* ------------------------------------------------
     Responsive
     ------------------------------------------------ */

  @media (max-width: 768px) {
    .ds__spacing-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .ds__spacing-meta {
      min-width: auto;
    }

    .ds__layout-grid {
      grid-template-columns: 1fr;
    }

    .ds__state-row {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }

    .ds__state-label {
      min-width: auto;
    }
  }

  /* ------------------------------------------------
     Portfolio link (fixed bottom-right)
     ------------------------------------------------ */

  .ds-link {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: var(--color-title);
    color: var(--color-bg);
    padding: 8px 16px;
    font-size: 0.75rem;
    text-decoration: none;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-family: var(--font-sans);
    border-radius: var(--radius-sm);
    transition: opacity 0.2s ease;
    z-index: 50;
  }

  .ds-link:hover {
    opacity: 0.8;
    color: var(--color-bg);
    text-decoration: none;
  }
</style>

<script>
  // Fade in header immediately
  const immediate = document.querySelectorAll('.fade-in, .side-nav.fade-in');
  requestAnimationFrame(() => {
    immediate.forEach((el) => el.classList.add('is-visible'));
  });

  // Scroll-triggered animations for sections
  const scrollElements = document.querySelectorAll('.animate');

  if (scrollElements.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0, rootMargin: '0px 0px -15% 0px' }
    );

    scrollElements.forEach((el) => observer.observe(el));
  }

  // Scroll-spy
  import { initScrollSpy } from '../scripts/scroll-spy';
  initScrollSpy();
</script>
