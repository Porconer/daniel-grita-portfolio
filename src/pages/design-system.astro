---
import Layout from '../layouts/Layout.astro';

const colors = [
  { name: 'Background', var: '--color-bg', value: '#ffffff', hasBorder: true },
  { name: 'Title', var: '--color-title', value: '#191d1a' },
  { name: 'Text', var: '--color-text', value: '#3a3f3b' },
  { name: 'Text Secondary', var: '--color-text-secondary', value: '#6b716c' },
  { name: 'Accent', var: '--color-accent', value: '#cff500' },
];

const spacing = [
  { name: 'XS', var: '--space-xs', value: '0.5rem (8px)' },
  { name: 'SM', var: '--space-sm', value: '1rem (16px)' },
  { name: 'MD', var: '--space-md', value: '2rem (32px)' },
  { name: 'LG', var: '--space-lg', value: '4rem (64px)' },
  { name: 'XL', var: '--space-xl', value: '6rem (96px)' },
  { name: '2XL', var: '--space-2xl', value: '10rem (160px)' },
];

const layout = [
  { name: 'Max Width', var: '--max-width', value: '1200px' },
  { name: 'Nav Width', var: '--nav-width', value: '160px' },
];
---

<Layout title="Design System — Portfolio">
  <div class="ds">
    <header class="ds__header">
      <h1 class="ds__title">Design System</h1>
      <p class="ds__subtitle">Daniel Grita Portfolio — Tokens, Typography & Components</p>
      <a href="/" class="ds__back">&larr; Back to Portfolio</a>
    </header>

    <!-- Colors -->
    <section class="ds__section">
      <h2 class="ds__section-title">Colors</h2>
      <div class="ds__colors">
        {colors.map((color) => (
          <div class="ds__color-card">
            <div
              class="ds__color-swatch"
              style={`background-color: var(${color.var});`}
            />
            <div class="ds__color-info">
              <span class="ds__color-name">{color.name}</span>
              <code class="ds__color-var">{color.var}</code>
              <code class="ds__color-value">{color.value}</code>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Typography -->
    <section class="ds__section">
      <h2 class="ds__section-title">Typography</h2>
      <p class="ds__section-note">Font family: <strong>Quantico</strong> — Weights: 400 (Regular), 700 (Bold)</p>

      <div class="ds__type-samples">
        <div class="ds__type-row">
          <div class="ds__type-meta">
            <code>h1</code>
            <span>clamp(2.5rem, 5vw, 4rem) / 700 / 1.1 / -0.03em</span>
          </div>
          <h1 class="ds__type-sample">Daniel Grita</h1>
        </div>

        <div class="ds__type-row">
          <div class="ds__type-meta">
            <code>h2</code>
            <span>0.875rem / 500 / uppercase / 0.08em</span>
          </div>
          <h2 class="ds__type-sample-h2">Section Label</h2>
        </div>

        <div class="ds__type-row">
          <div class="ds__type-meta">
            <code>h3</code>
            <span>1.25rem / 600 / 1.3</span>
          </div>
          <h3 class="ds__type-sample">Senior Product Designer</h3>
        </div>

        <div class="ds__type-row">
          <div class="ds__type-meta">
            <code>p (body)</code>
            <span>1rem / 400 / 1.7 / secondary color</span>
          </div>
          <p class="ds__type-sample">Designer focused on fintech — building clear, considered interfaces for complex financial products.</p>
        </div>

        <div class="ds__type-row">
          <div class="ds__type-meta">
            <code>.small</code>
            <span>0.8125rem / 400 / secondary color</span>
          </div>
          <span class="ds__type-sample ds__type-small">Navigation / Meta text</span>
        </div>

        <div class="ds__type-row">
          <div class="ds__type-meta">
            <code>a (link)</code>
            <span>underline / 3px offset / color transition</span>
          </div>
          <a href="#" class="ds__type-sample ds__type-link" onclick="return false">hello@example.com</a>
        </div>
      </div>
    </section>

    <!-- Spacing -->
    <section class="ds__section">
      <h2 class="ds__section-title">Spacing Scale</h2>
      <div class="ds__spacing-list">
        {spacing.map((sp) => (
          <div class="ds__spacing-row">
            <div class="ds__spacing-meta">
              <strong>{sp.name}</strong>
              <code>{sp.var}</code>
              <span>{sp.value}</span>
            </div>
            <div class="ds__spacing-bar" style={`width: var(${sp.var})`} />
          </div>
        ))}
      </div>
    </section>

    <!-- Layout -->
    <section class="ds__section">
      <h2 class="ds__section-title">Layout</h2>
      <div class="ds__layout-tokens">
        {layout.map((l) => (
          <div class="ds__layout-row">
            <strong>{l.name}</strong>
            <code>{l.var}</code>
            <span>{l.value}</span>
          </div>
        ))}
      </div>

      <div class="ds__layout-diagram">
        <div class="ds__layout-grid">
          <div class="ds__layout-main">
            <span>Main Content (1fr)</span>
          </div>
          <div class="ds__layout-nav">
            <span>Nav (160px)</span>
          </div>
        </div>
        <div class="ds__layout-label">max-width: 1200px</div>
      </div>
    </section>

    <!-- Components -->
    <section class="ds__section">
      <h2 class="ds__section-title">Components</h2>

      <!-- Section Label -->
      <div class="ds__component">
        <h3 class="ds__component-name">Section Label</h3>
        <div class="ds__component-preview">
          <h2 class="section__label">About</h2>
        </div>
      </div>

      <!-- Work Entry -->
      <div class="ds__component">
        <h3 class="ds__component-name">Work Entry</h3>
        <div class="ds__component-preview">
          <article class="work__entry">
            <span class="work__period">2025 — Present</span>
            <h3 class="work__title">Senior Product Designer</h3>
            <span class="work__company">Fintech Company</span>
            <p class="work__description">Leading the design of consumer-facing financial products.</p>
            <div class="work__image">
              <div class="work__image-placeholder">
                <span>Image placeholder</span>
              </div>
            </div>
          </article>
        </div>
      </div>

      <!-- Side Navigation -->
      <div class="ds__component">
        <h3 class="ds__component-name">Side Navigation</h3>
        <div class="ds__component-preview ds__component-preview--dark">
          <nav class="ds__side-nav-sample">
            <a href="#" onclick="return false">Top</a>
            <a href="#" onclick="return false">About</a>
            <a href="#" onclick="return false">Work</a>
            <a href="#" onclick="return false">Connect</a>
          </nav>
        </div>
      </div>

      <!-- Contact Links -->
      <div class="ds__component">
        <h3 class="ds__component-name">Contact Links</h3>
        <div class="ds__component-preview">
          <div class="contact__links">
            <a href="#" onclick="return false">hello@example.com</a>
            <a href="#" onclick="return false">LinkedIn</a>
            <a href="#" onclick="return false">Dribbble</a>
          </div>
        </div>
      </div>
    </section>

    <!-- States -->
    <section class="ds__section">
      <h2 class="ds__section-title">Interactive States</h2>
      <div class="ds__states">
        <div class="ds__state-row">
          <span class="ds__state-label">Link — Default</span>
          <a class="ds__state-demo" style="color: var(--color-text-secondary); text-decoration: underline; text-underline-offset: 3px; pointer-events: none;">hello@example.com</a>
        </div>
        <div class="ds__state-row">
          <span class="ds__state-label">Link — Hover</span>
          <a class="ds__state-demo" style="color: var(--color-text); text-decoration: underline; text-underline-offset: 3px; pointer-events: none;">hello@example.com</a>
        </div>
        <div class="ds__state-row">
          <span class="ds__state-label">Nav Link — Default</span>
          <a class="ds__state-demo" style="color: var(--color-text-secondary); font-size: 0.8125rem; pointer-events: none;">About</a>
        </div>
        <div class="ds__state-row">
          <span class="ds__state-label">Nav Link — Hover</span>
          <a class="ds__state-demo" style="color: var(--color-text); font-size: 0.8125rem; pointer-events: none;">About</a>
        </div>
        <div class="ds__state-row">
          <span class="ds__state-label">Selection</span>
          <span class="ds__state-demo ds__state-selection">Selected text</span>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .ds {
    max-width: 960px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-md);
  }

  .ds__header {
    margin-bottom: var(--space-xl);
  }

  .ds__title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: var(--space-xs);
  }

  .ds__subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .ds__back {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Sections */
  .ds__section {
    margin-bottom: var(--space-2xl);
  }

  .ds__section-title {
    display: inline-block;
    font-size: 0.75rem !important;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text);
    margin-bottom: var(--space-md);
    padding: 0.25rem 0.75rem;
    background-color: var(--color-accent);
    border-radius: 2px;
  }

  .ds__section-note {
    font-size: 0.875rem;
    margin-bottom: var(--space-md);
  }

  /* Colors */
  .ds__colors {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-md);
  }

  .ds__color-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .ds__color-swatch {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 8px;
  }

  .ds__color-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ds__color-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .ds__color-var {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    font-family: var(--font-sans);
  }

  .ds__color-value {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    font-family: var(--font-sans);
  }

  /* Typography */
  .ds__type-samples {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .ds__type-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .ds__type-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  .ds__type-meta code {
    background: #f5f5f5;
    padding: 2px 8px;
    border-radius: 4px;
    font-family: var(--font-sans);
    font-weight: 700;
    color: var(--color-text);
  }

  .ds__type-sample-h2 {
    color: var(--color-text-secondary);
  }

  .ds__type-small {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .ds__type-link {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .ds__type-link:hover {
    color: var(--color-accent);
  }

  /* Spacing */
  .ds__spacing-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .ds__spacing-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .ds__spacing-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    min-width: 320px;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .ds__spacing-meta strong {
    color: var(--color-text);
    min-width: 32px;
  }

  .ds__spacing-meta code {
    background: #f5f5f5;
    padding: 2px 8px;
    border-radius: 4px;
    font-family: var(--font-sans);
    font-size: 0.75rem;
  }

  .ds__spacing-bar {
    height: 20px;
    background-color: var(--color-text);
    border-radius: 2px;
    min-width: 8px;
  }

  /* Layout */
  .ds__layout-tokens {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    margin-bottom: var(--space-md);
    font-size: 0.8125rem;
  }

  .ds__layout-row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-text-secondary);
  }

  .ds__layout-row strong {
    color: var(--color-text);
    min-width: 100px;
  }

  .ds__layout-row code {
    background: #f5f5f5;
    padding: 2px 8px;
    border-radius: 4px;
    font-family: var(--font-sans);
    font-size: 0.75rem;
  }

  .ds__layout-diagram {
    margin-top: var(--space-md);
  }

  .ds__layout-grid {
    display: grid;
    grid-template-columns: 1fr 160px;
    gap: var(--space-sm);
    height: 120px;
  }

  .ds__layout-main,
  .ds__layout-nav {
    background: #f5f5f5;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .ds__layout-label {
    text-align: center;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  /* Components */
  .ds__component {
    margin-bottom: var(--space-lg);
  }

  .ds__component-name {
    font-size: 0.875rem;
    font-weight: 700;
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }

  .ds__component-preview {
    border-radius: 8px;
    padding: var(--space-md);
    background: #fafafa;
  }

  .ds__component-preview--dark {
    background: #fafafa;
  }

  /* Side nav sample */
  .ds__side-nav-sample {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    text-align: right;
    max-width: 160px;
    margin-left: auto;
  }

  .ds__side-nav-sample a {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.25rem 0;
    transition: color 0.2s ease;
  }

  .ds__side-nav-sample a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  /* Reuse component styles from index */
  .section__label {
    display: inline-block;
    margin-bottom: var(--space-md);
    padding: 0.25rem 0.75rem;
    background-color: var(--color-accent);
    border-radius: 2px;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .work__entry {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .work__period {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  .work__title {
    font-size: 1.25rem;
    font-weight: 600;
  }

  .work__company {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }

  .work__description {
    max-width: 560px;
    margin-top: var(--space-xs);
  }

  .work__image {
    margin-top: var(--space-sm);
  }

  .work__image-placeholder {
    width: 100%;
    max-width: 560px;
    aspect-ratio: 16 / 10;
    background-color: #f5f5f5;
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }

  .contact__links {
    display: flex;
    gap: var(--space-md);
  }

  .contact__links a {
    font-size: 0.9375rem;
    text-decoration: underline;
    text-underline-offset: 3px;
    color: var(--color-text-secondary);
  }

  .contact__links a:hover {
    color: var(--color-accent);
  }

  /* States */
  .ds__states {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .ds__state-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .ds__state-label {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    min-width: 160px;
  }

  .ds__state-demo {
    font-family: var(--font-sans);
  }

  .ds__state-selection {
    background: var(--color-text);
    color: var(--color-bg);
    padding: 2px 6px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .ds {
      padding: var(--space-lg) var(--space-sm);
    }

    .ds__spacing-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .ds__spacing-meta {
      min-width: auto;
    }

    .ds__layout-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
