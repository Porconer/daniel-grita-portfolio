---
import Layout from '../../layouts/Layout.astro';
import Contact from '../../components/Contact.astro';
import SideNav from '../../components/SideNav.astro';
import MobileNav from '../../components/MobileNav.astro';
import { allEntries } from '../../data/work';
import { caseStudies } from '../../data/case-studies';
import { imgDims } from '../../data/image-dimensions';
import { imgAlt } from '../../data/image-alt';

export function getStaticPaths() {
  return allEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: entry,
  }));
}

const { title, company, period, description, image, slug, projectHero, galleryImages, projectDescription } = Astro.props;
const entry = allEntries.find((e) => e.slug === slug);
const galleryLayout = entry?.galleryLayout;
const gallerySections = entry?.gallerySections;
const uniformImages = entry?.uniformImages;
const galleryAspectRatio = entry?.galleryAspectRatio;
const heroLandscape = entry?.heroLandscape;
const heroVideo = entry?.heroVideo;
const caseStudy = caseStudies[slug];
const displayDescription = projectDescription || description;

const stripTags = (s: string) => s.replace(/<[^>]*>/g, '');
const truncate = (s: string, n: number) => s.length > n ? s.slice(0, n - 1).trimEnd() + '…' : s;
const metaDescription = truncate(stripTags(description), 160);
const ogImage = projectHero || (image && !image.includes('work-') ? image : undefined);
---

<Layout
  title={`${company} | Daniel Grita`}
  description={metaDescription}
  ogImage={ogImage}
  ogType="article"
>
  {caseStudy ? (
    <!-- Case study layout -->
    <div id="top"></div>

    <MobileNav items={caseStudy.navItems} />

    <div class="page">
      <main class="main-content">
        <!-- Header -->
        <header class="cs__header fade-in">
          <a href="/#work" class="cs__back">← Back to portfolio</a>
          <span class="cs__period">{period}</span>
          <h1 class="cs__company">{company}</h1>
          <p class="cs__role">{title}</p>
        </header>

        <!-- Hero image -->
        {image && !image.includes('work-') && (
          <div class="cs__hero fade-in">
            <img src={image} alt={imgAlt(image)} width={imgDims(image)?.width} height={imgDims(image)?.height} />
          </div>
        )}

        <!-- Sections -->
        {caseStudy.sections.map((section) => (
          <section class="cs__section animate" id={section.id}>
            {section.label && (
              <span class="cs__label">{section.label}</span>
            )}

            {section.title && (
              <h2 class="cs__title">{section.title}</h2>
            )}

            {section.body && (
              <div class="cs__body">
                {section.body.split('\n\n').map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
            )}

            {section.cards && (
              <div class={`cs__cards ${section.cards.length === 2 ? 'cs__cards--two' : ''}`}>
                {section.cards.map((card) => (
                  <div class="cs__card">
                    <h3 class="cs__card-title">{card.title}</h3>
                    <p class="cs__card-desc">{card.description}</p>
                  </div>
                ))}
              </div>
            )}

            {section.images && section.images.length > 0 ? (
              <figure class="cs__figure">
                <div class={`cs__gallery${section.uniformImages ? ' cs__gallery--uniform' : ''}${section.galleryLayout === 'stacked-right' ? ' cs__gallery--stacked-right' : ''}`}>
                  {section.images.map((src) => (
                    <img src={src} alt={imgAlt(src)} loading="lazy" width={imgDims(src)?.width} height={imgDims(src)?.height} />
                  ))}
                </div>
                {section.imageCaption && (
                  <figcaption class="cs__caption">{section.imageCaption}</figcaption>
                )}
              </figure>
            ) : section.images === undefined ? (
              <div class="cs__image-placeholder">
                <span>Image placeholder</span>
              </div>
            ) : null}

            {section.highlight && (
              <div class="cs__highlight">
                <h3 class="cs__highlight-title">Problem to Solve</h3>
                <p>{section.highlight}</p>
              </div>
            )}
          </section>
        ))}

      </main>

      <SideNav items={caseStudy.navItems} />

      <Contact />
    </div>

    <!-- Lightbox -->
    <div class="lightbox" role="dialog" aria-modal="true" aria-label="Enlarged image view" aria-hidden="true">
      <button class="lightbox__close" type="button" aria-label="Close image">&times;</button>
      <img class="lightbox__img" src="" alt="" />
    </div>
  ) : (
    <!-- Simple layout (no case study) -->
    <div id="top"></div>

    <MobileNav items={[{ id: 'top', label: 'Top' }, { id: 'description', label: 'Description' }, { id: 'connect', label: 'Connect' }]} />

    <div class="page">
      <main class="main-content">
        <div class="project__top fade-in">
          <a href="/#work" class="project__back">← Back to portfolio</a>
        </div>

        <header class="project__header fade-in">
          <span class="project__period">{period}</span>
          <h1 class="project__title">{company}</h1>
          <p class="project__role">{title}</p>
        </header>

        {projectHero && (
          <div class:list={['project__hero fade-in', { 'project__hero--landscape': heroLandscape }]}>
            <img src={projectHero} alt={imgAlt(projectHero)} width={imgDims(projectHero)?.width} height={imgDims(projectHero)?.height} />
          </div>
        )}

        {heroVideo && (
          <div class="project__hero project__hero--video fade-in">
            <video
              class="project__video"
              controls
              preload="metadata"
              playsinline
              poster={heroVideo.poster}
              width={imgDims(heroVideo.poster)?.width}
              height={imgDims(heroVideo.poster)?.height}
            >
              <source src={heroVideo.src} type="video/mp4" />
            </video>
          </div>
        )}

        {!gallerySections && (
          <section id="description">
            <div class="project__description">
              {displayDescription.split('\n\n').map((paragraph: string) => (
                <p class="animate">{paragraph}</p>
              ))}
            </div>
          </section>
        )}

        {gallerySections ? (
          <section id="description" class="project__content">
            {gallerySections.map((section) => (
              <div class="project__content-block">
                {section.text && <p class="project__gallery-text animate">{section.text}</p>}
                {section.video ? (
                  <div class="project__gallery project__gallery--single animate">
                    <video
                      class="project__video"
                      controls
                      preload="metadata"
                      playsinline
                      poster={section.video.poster}
                      width={imgDims(section.video.poster)?.width}
                      height={imgDims(section.video.poster)?.height}
                    >
                      <source src={section.video.src} type="video/mp4" />
                    </video>
                  </div>
                ) : section.images.length > 0 && (
                  <div class:list={['project__gallery animate', { 'project__gallery--single': section.images.length === 1 }]}>
                    {section.images.map((src: string, i: number) => (
                      <img src={src} alt={section.alts?.[i] || imgAlt(src)} loading="lazy" width={imgDims(src)?.width} height={imgDims(src)?.height} style={section.aspectRatio ? `aspect-ratio: ${section.aspectRatio}` : undefined} />
                    ))}
                  </div>
                )}
                {section.title && (section.images.length > 0 || section.video) && <p class="cs__caption animate">{section.title}</p>}
              </div>
            ))}
          </section>
        ) : galleryImages && galleryImages.length > 0 ? (
          <div class:list={['project__gallery animate', { 'project__gallery--stacked-right': galleryLayout === 'stacked-right', 'project__gallery--uniform': uniformImages }]}>
            {galleryImages.map((src: string) => (
              <img src={src} alt={imgAlt(src)} loading="lazy" width={imgDims(src)?.width} height={imgDims(src)?.height} style={galleryAspectRatio ? `aspect-ratio: ${galleryAspectRatio}` : undefined} />
            ))}
          </div>
        ) : null}

      </main>

      <SideNav items={[{ id: 'top', label: 'Top' }, { id: 'description', label: 'Description' }, { id: 'connect', label: 'Connect' }]} />

      <Contact />
    </div>

    <!-- Lightbox -->
    <div class="lightbox" role="dialog" aria-modal="true" aria-label="Enlarged image view" aria-hidden="true">
      <button class="lightbox__close" type="button" aria-label="Close image">&times;</button>
      <img class="lightbox__img" src="" alt="" />
    </div>
  )}
</Layout>

<style>
  /* ------------------------------------------------
     Case Study — Header
     ------------------------------------------------ */

  .cs__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .cs__back {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
    margin-bottom: var(--space-sm);
    transition: color 0.2s ease;
  }

  .cs__back:hover {
    color: var(--color-hover);
  }

  .cs__period {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  .cs__company {
    font-size: clamp(2rem, 1.25rem + 3.75vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .cs__role {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
  }

  /* ------------------------------------------------
     Case Study — Hero Image
     ------------------------------------------------ */

  .cs__hero {
    margin-top: var(--space-lg);
  }

  .cs__hero img {
    width: 100%;
    border-radius: var(--radius-md);
  }

  /* ------------------------------------------------
     Case Study — Sections
     ------------------------------------------------ */

  .cs__section {
    margin-top: var(--space-xl);
  }

  .cs__label {
    display: inline-block;
    margin-bottom: var(--space-sm);
    padding: 0.25rem 0.75rem;
    background-color: var(--color-accent);
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-on-accent);
  }

  .cs__title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-title);
    margin-bottom: var(--space-sm);
  }

  .cs__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .cs__body p {
    line-height: 1.7;
  }

  /* ------------------------------------------------
     Case Study — Image Gallery
     ------------------------------------------------ */

  .cs__figure {
    margin-top: var(--space-md);
  }

  .cs__hero,
  .cs__gallery {
    background-color: var(--color-img-bg);
    border-radius: var(--radius-lg);
    padding: var(--space-md);
  }

  .cs__gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(0, 1fr));
    gap: var(--space-sm);
    align-items: start;
  }

  .cs__gallery img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: var(--radius-md);
  }

  .cs__gallery--uniform img {
    aspect-ratio: 4 / 3;
  }

  .cs__gallery--stacked-right {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
  }

  .cs__gallery--stacked-right img:first-child {
    grid-row: 1 / -1;
    height: 0;
    min-height: 100%;
    object-fit: cover;
  }

  .cs__caption {
    text-align: center;
    font-size: 0.875rem;
    font-style: italic;
    color: var(--color-text-secondary);
    margin-top: var(--space-sm);
  }

  @media (max-width: 768px) {
    .cs__gallery {
      grid-template-columns: 1fr;
    }

    .cs__gallery--stacked-right {
      grid-template-rows: auto;
    }

    .cs__gallery--stacked-right img:first-child {
      grid-row: auto;
    }
  }

  /* ------------------------------------------------
     Case Study — Image Placeholder
     ------------------------------------------------ */

  .cs__image-placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    margin-top: var(--space-md);
    background-color: var(--color-border);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }

  /* ------------------------------------------------
     Case Study — Cards
     ------------------------------------------------ */

  .cs__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .cs__cards--two {
    grid-template-columns: repeat(2, 1fr);
  }

  .cs__card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-md);
  }

  .cs__card-title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-title);
    margin-bottom: var(--space-xs);
  }

  .cs__card-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  /* ------------------------------------------------
     Case Study — Highlight Banner
     ------------------------------------------------ */

  .cs__highlight {
    margin-top: var(--space-md);
    padding: var(--space-md) var(--space-md);
    background-color: var(--color-accent);
    border-radius: var(--radius-md);
  }

  .cs__highlight-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-on-accent);
    margin-bottom: var(--space-xs);
  }

  .cs__highlight p {
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.6;
    color: var(--color-on-accent);
    max-width: none;
  }

  /* ------------------------------------------------
     Case Study — Responsive
     ------------------------------------------------ */

  @media (max-width: 768px) {
    .cs__cards {
      grid-template-columns: 1fr;
    }

    .cs__cards--two {
      grid-template-columns: 1fr;
    }
  }

  /* ------------------------------------------------
     Case Study — Scroll animation overrides (base in global.css)
     ------------------------------------------------ */

  .cs__header.fade-in {
    transition-delay: 0s;
  }

  .cs__hero.fade-in {
    transition-delay: 0.2s;
  }

  .project__top.fade-in { transition-delay: 0s; }
  .project__header.fade-in { transition-delay: 0.15s; }
  .project__hero.fade-in { transition-delay: 0.3s; }

  /* ------------------------------------------------
     Simple Layout (non case-study fallback)
     ------------------------------------------------ */

  .project__section {
    margin-top: var(--space-xl);
  }

  .project__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .project__back {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .project__back:hover {
    color: var(--color-hover);
  }

  .project__header {
    margin-top: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .project__period {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  .project__title {
    font-weight: 700;
  }

  .project__role {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
  }

  .project__hero {
    margin-top: var(--space-lg);
    background-color: var(--color-img-bg);
    border-radius: var(--radius-lg);
    padding: var(--space-md);
  }

  .project__hero img {
    width: 100%;
    border-radius: var(--radius-md);
    object-fit: cover;
  }

  .project__hero--landscape img {
    object-fit: contain;
  }

  .project__video {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-md);
    background: #000;
  }

  .project__description {
    max-width: none;
    margin-top: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .project__description p {
    line-height: 1.7;
  }

  .project__content {
    margin-top: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-content-gap);
  }

  .project__gallery-text {
    line-height: 1.7;
    margin-bottom: var(--space-content-gap);
  }

  .project__content-block .project__gallery {
    margin-top: 0;
  }

  .project__gallery {
    margin-top: var(--space-lg);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-sm);
    background-color: var(--color-img-bg);
    border-radius: var(--radius-lg);
    padding: var(--space-md);
  }

  .project__gallery img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: var(--radius-md);
  }

  .project__gallery--single {
    grid-template-columns: 1fr;
  }



  .project__gallery--uniform img {
    aspect-ratio: 3 / 4;
  }

  .project__gallery--stacked-right img:nth-child(n+4):nth-child(-n+10) {
    height: 550px;
  }

  .project__gallery--stacked-right {
    grid-template-rows: auto auto;
  }

  .project__gallery--stacked-right img:first-child {
    grid-row: 1 / 3;
    height: 0;
    min-height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .project__gallery {
      grid-template-columns: 1fr;
    }

    .project__gallery--stacked-right {
      grid-template-rows: auto;
    }

    .project__gallery--stacked-right img:first-child {
      grid-row: auto;
      height: auto;
      min-height: 0;
    }
  }

  /* ------------------------------------------------
     Lightbox
     ------------------------------------------------ */

  .cs__gallery img,
  .cs__hero img,
  .project__gallery img {
    cursor: zoom-in;
  }

  .cs__gallery img:focus-visible,
  .cs__hero img:focus-visible,
  .project__gallery img:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 4px;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.85);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .lightbox.is-open {
    opacity: 1;
    visibility: visible;
  }

  .lightbox__img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-md);
    transform: scale(0.95);
    transition: transform 0.3s ease;
  }

  .lightbox.is-open .lightbox__img {
    transform: scale(1);
  }

  .lightbox__close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: #fff;
    font-size: 2rem;
    cursor: pointer;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: var(--touch-target-min);
    min-width: 44px;
    padding: 0.25rem 0.5rem;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .lightbox__close:hover {
    opacity: 1;
  }
</style>

<script>
  // Fade in header, hero, and side nav immediately
  const immediate = document.querySelectorAll('.fade-in');
  requestAnimationFrame(() => {
    immediate.forEach((el) => el.classList.add('is-visible'));
  });

  // Scroll-triggered animations for sections
  const scrollElements = document.querySelectorAll('.animate');

  if (scrollElements.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0, rootMargin: '0px 0px -15% 0px' }
    );

    scrollElements.forEach((el) => observer.observe(el));
  }

  // Scroll-spy: highlight active nav link + floating dot
  import { initScrollSpy } from '../../scripts/scroll-spy';
  initScrollSpy();

  // Lightbox
  const lightbox = document.querySelector('.lightbox') as HTMLElement | null;
  const lightboxImg = document.querySelector('.lightbox__img') as HTMLImageElement | null;
  const lightboxClose = lightbox?.querySelector('.lightbox__close') as HTMLButtonElement | null;

  if (lightbox && lightboxImg && lightboxClose) {
    let lastFocused: HTMLElement | null = null;

    const openFrom = (img: HTMLImageElement) => {
      lastFocused = img;
      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt;
      lightbox.classList.add('is-open');
      lightbox.setAttribute('aria-hidden', 'false');
      lightboxClose.focus();
    };

    const close = () => {
      lightbox.classList.remove('is-open');
      lightbox.setAttribute('aria-hidden', 'true');
      if (lastFocused) {
        lastFocused.focus();
        lastFocused = null;
      }
    };

    document.querySelectorAll<HTMLImageElement>('.cs__gallery img, .cs__hero img, .project__gallery img').forEach((img) => {
      img.setAttribute('tabindex', '0');
      img.setAttribute('role', 'button');
      img.setAttribute('aria-label', `Enlarge image: ${img.alt || 'gallery image'}`);

      img.addEventListener('click', () => openFrom(img));
      img.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openFrom(img);
        }
      });
    });

    lightboxClose.addEventListener('click', close);
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) close();
    });

    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('is-open')) return;
      if (e.key === 'Escape') {
        close();
      } else if (e.key === 'Tab') {
        e.preventDefault();
        lightboxClose.focus();
      }
    });
  }
</script>
