---
import Layout from '../layouts/Layout.astro';
import Contact from '../components/Contact.astro';
import SideNav from '../components/SideNav.astro';
import MobileNav from '../components/MobileNav.astro';
import { work, projects } from '../data/work';
import type { WorkEntry } from '../data/work';
import { caseStudies } from '../data/case-studies';
import { imgDims } from '../data/image-dimensions';
import { imgAlt } from '../data/image-alt';

const hasProjectPage = (entry: WorkEntry) => entry.projectDescription || entry.projectHero || entry.heroVideo;
const linkLabel = (entry: WorkEntry) => caseStudies[entry.slug] ? 'View use case →' : 'View project →';

const navItems = [
  { id: 'top', label: 'Top' },
  { id: 'about', label: 'About' },
  { id: 'work', label: 'Work' },
  { id: 'projects', label: 'Projects' },
  { id: 'connect', label: 'Connect' },
];
---

<Layout
  title="Daniel Grita | Graphic and Web Design based in Barcelona"
  description="Portuguese visual artist based in Barcelona. Portfolio of graphic design, web design, creative direction, and photography across fintech, beauty, and editorial work."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Daniel Grita',
    jobTitle: 'Graphic and Web Designer',
    description: 'Portuguese visual artist based in Barcelona, working in graphic design, web design, and creative direction.',
    url: Astro.site?.href,
    nationality: 'Portuguese',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Barcelona',
      addressCountry: 'ES',
    },
    knowsAbout: ['Graphic Design', 'Web Design', 'Creative Direction', 'Photography', 'Art Direction', 'UI/UX Design'],
  })} />
  <div id="top"></div>

  <MobileNav items={navItems} />

  <div class="page">
    <main class="main-content">
      <!-- Hero -->
      <section class="section fade-in hero">
        <h1 class="hero__name">Daniel Grita</h1>
        <p class="hero__bio">
          Portuguese Visual Artist based in Barcelona. Wrestling daily with
          <strong>Graphic Design</strong>, <strong>Web Design</strong>, and <strong>Creative Direction</strong> to turn complex
          ideas into visual stories.
        </p>
      </section>

      <!-- About -->
      <section class="section fade-in about" id="about">
        <h2 class="section__label">About</h2>
        <div class="about__content">
          <p>
            With over 10 years of experience in design and content creation,
            I've had the opportunity to work and study across Portugal,
            Holland, and now Spain.
          </p>
          <p>
            I started early in the Graffiti and Street Art culture, branching
            out into Graphic Design, Fine Art, and Photography along the way.
          </p>
          <p>
            I'm a bit of a generalist at heart. I love picking up new tools
            and crossing into new disciplines, whether that's AI, Web Design,
            Photography, or Video. The variety is what keeps the work
            exciting.
          </p>
        </div>
      </section>

      <!-- Work -->
      <section class="section fade-in work" id="work">
        <h2 class="section__label">Work</h2>
        <div class="work__list">
          {work.map((entry, i) => (
            <article class={`work__entry ${i === 0 ? 'fade-in' : 'animate'}`}>
              <span class="work__period">{entry.period}</span>
              <h3 class="work__title">{entry.company}</h3>
              <span class="work__company">{entry.title}</span>
              <p class="work__description">{entry.description}</p>
              {!entry.image.includes('work-') && (
                <div class="work__image">
                  <img src={entry.image} alt={imgAlt(entry.image)} loading="lazy" width={imgDims(entry.image)?.width} height={imgDims(entry.image)?.height} />
                </div>
              )}
              <a href={`/work/${entry.slug}`} class="work__link">{linkLabel(entry)}</a>
            </article>
          ))}
        </div>
      </section>

      <!-- Projects -->
      <section class="section work animate" id="projects">
        <h2 class="section__label">Projects</h2>
        <div class="work__list">
          {projects.map((entry) => (
            <article class="work__entry animate">
              <span class="work__period">{entry.period}</span>
              <h3 class="work__title">{entry.company}</h3>
              <span class="work__company">{entry.title}</span>
              <p class="work__description">{entry.description}</p>
              {!entry.image.includes('work-') && (
                <div class="work__image">
                  <img src={entry.image} alt={imgAlt(entry.image)} loading="lazy" width={imgDims(entry.image)?.width} height={imgDims(entry.image)?.height} />
                </div>
              )}
              {hasProjectPage(entry) && (
                <a href={`/work/${entry.slug}`} class="work__link">{linkLabel(entry)}</a>
              )}
            </article>
          ))}
        </div>
      </section>

    </main>

    <SideNav items={navItems} />

    <Contact />
  </div>

  <a href="/design-system" class="ds-link">Design System</a>
</Layout>

<style>
  /* ------------------------------------------------
     Hero
     ------------------------------------------------ */

  .hero {
    padding-bottom: var(--space-sm);
  }

  .hero__name {
    margin-bottom: var(--space-xs);
  }

  .hero__bio {
    font-size: 1.125rem;
    line-height: 1.7;
  }

  /* ------------------------------------------------
     About
     ------------------------------------------------ */

  .about__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  /* ------------------------------------------------
     Work
     ------------------------------------------------ */

  .work__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .work__entry {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .work__period {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  .work__title {
    font-size: 1.25rem;
    font-weight: 600;
  }

  .work__company {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }

  .work__description {
    margin-top: var(--space-xs);
  }

  .work__image {
    margin-top: var(--space-sm);
  }

  .work__image img {
    width: 100%;
    aspect-ratio: 1905 / 911;
    object-fit: cover;
    border-radius: var(--radius-md);
  }

  .work__link {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
    margin-top: var(--space-xs);
  }

  .work__link:hover {
    color: var(--color-hover);
  }

  /* ------------------------------------------------
     Scroll animation overrides (base in global.css)
     ------------------------------------------------ */

  .section {
    opacity: 0;
    transform: translateY(25px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .section.fade-in {
    transform: none;
  }

  .hero { transition-delay: 0s; }
  .about { transition-delay: 0.3s; }
  #work { transition-delay: 0.6s; }
  .work__entry.fade-in { transition-delay: 0.6s; }

  .section.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .work__entry.fade-in {
    opacity: 0;
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .work__entry.fade-in.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

</style>

<script>
  // Fade in hero, about, work label, and first project immediately on load
  const immediate = document.querySelectorAll('.section.fade-in, .work__entry.fade-in, .side-nav.fade-in');
  requestAnimationFrame(() => {
    immediate.forEach((el) => el.classList.add('is-visible'));
  });

  // Scroll-triggered animations for everything else
  const scrollElements = document.querySelectorAll('.section:not(.fade-in), .animate');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0, rootMargin: '0px 0px -15% 0px' }
  );

  scrollElements.forEach((el) => observer.observe(el));

  // Scroll-spy: highlight active nav link + floating dot
  import { initScrollSpy } from '../scripts/scroll-spy';
  initScrollSpy();
</script>
