---
import Layout from '../layouts/Layout.astro';
import { work } from '../data/work';
---

<Layout title="Designer — Portfolio">
  <div id="top"></div>

  <!-- Mobile Top Navigation -->
  <nav class="mobile-nav" aria-label="Mobile navigation">
    <a href="#top" class="mobile-nav__link">Top</a>
    <a href="#about" class="mobile-nav__link">About</a>
    <a href="#work" class="mobile-nav__link">Work</a>
    <a href="#contact" class="mobile-nav__link">Connect</a>
    <button class="theme-toggle" type="button" aria-label="Toggle dark mode">
      <span class="theme-toggle__icon theme-toggle__icon--light">☀</span>
      <span class="theme-toggle__icon theme-toggle__icon--dark">☾</span>
    </button>
  </nav>

  <div class="page">
    <main class="main-content">
      <!-- Hero -->
      <section class="section fade-in hero">
        <h1 class="hero__name">Daniel Grita</h1>
        <p class="hero__bio">
          Portuguese Visual Artist based in Barcelona. Wrestling daily with
          Graphic Design, Web Design, and Creative Direction to turn complex
          ideas into visual stories.
        </p>
      </section>

      <!-- About -->
      <section class="section fade-in about" id="about">
        <h2 class="section__label">About</h2>
        <div class="about__content">
          <p>
            With over 5 years of experience in the design field and content
            creation, I've had the opportunity to work and study across
            Portugal, Holland, and now Spain.
          </p>
          <p>
            My creative journey is deeply rooted in the Graffiti Culture and
            Graphic Design world, as well as Photography, Fine Art, and
            Street Art.
          </p>
          <p>
            I'm always excited to create, collaborate and learn new skills
            like AI, Web Design and 3D.
          </p>
        </div>
      </section>

      <!-- Work -->
      <section class="section fade-in work" id="work">
        <h2 class="section__label">Work</h2>
        <div class="work__list">
          {work.map((entry, i) => (
            <article class={`work__entry ${i === 0 ? 'fade-in' : 'animate'}`}>
              <span class="work__period">{entry.period}</span>
              <h3 class="work__title">{entry.title}</h3>
              <span class="work__company">{entry.company}</span>
              <p class="work__description">{entry.description}</p>
              <div class="work__image">
                {entry.image.includes('work-') ? (
                  <div class="work__image-placeholder">
                    <span>Image placeholder</span>
                  </div>
                ) : (
                  <img src={entry.image} alt={`${entry.company} project`} />
                )}
              </div>
              <a href={`/work/${entry.slug}`} class="work__link">View project →</a>
            </article>
          ))}
        </div>
      </section>

      <!-- Contact -->
      <section class="section contact" id="contact">
        <h2 class="section__label">Connect</h2>
        <div class="contact__content">
          <p>
            Open to freelance projects, collaborations, and new opportunities.
            <br />Let's talk.
          </p>
          <div class="contact__links">
            <a href="mailto:danielgrita@gmail.com?subject=Job%20Request">danielgrita@gmail.com</a>
            <a href="tel:+34623980135">+34 623 980 135</a>
            <a href="https://www.linkedin.com/in/danielgrita/" target="_blank" rel="noopener">LinkedIn</a>
            <a href="https://www.instagram.com/danielgrita" target="_blank" rel="noopener">Instagram</a>
          </div>
        </div>
      </section>
    </main>

    <!-- Side Navigation -->
    <nav class="side-nav fade-in" aria-label="Page navigation">
      <div class="side-nav__inner">
        <a href="#top" class="side-nav__link">Top</a>
        <a href="#about" class="side-nav__link">About</a>
        <a href="#work" class="side-nav__link">Work</a>
        <a href="#contact" class="side-nav__link">Connect</a>
        <button class="theme-toggle" type="button" aria-label="Toggle dark mode">
          <span class="theme-toggle__icon theme-toggle__icon--light">☀</span>
          <span class="theme-toggle__icon theme-toggle__icon--dark">☾</span>
        </button>
      </div>
    </nav>
  </div>


</Layout>

<style>
  /* ------------------------------------------------
     Hero
     ------------------------------------------------ */

  .hero {
    padding-bottom: var(--space-sm);
  }

  .hero__name {
    margin-bottom: var(--space-xs);
  }

  .hero__bio {
    max-width: 560px;
    font-size: 1.125rem;
    line-height: 1.7;
  }

  /* ------------------------------------------------
     Section label
     ------------------------------------------------ */

  .section__label {
    display: inline-block;
    margin-bottom: var(--space-md);
    padding: 0.25rem 0.75rem;
    background-color: var(--color-accent);
    border-radius: 2px;
    font-size: 0.75rem;
    font-weight: 700;
    color: #191d1a;
  }

  /* ------------------------------------------------
     About
     ------------------------------------------------ */

  .about__content {
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  /* ------------------------------------------------
     Work
     ------------------------------------------------ */

  .work__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .work__entry {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .work__period {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  .work__title {
    font-size: 1.25rem;
    font-weight: 600;
  }

  .work__company {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }

  .work__description {
    max-width: 560px;
    margin-top: var(--space-xs);
  }

  .work__image {
    margin-top: var(--space-sm);
  }

  .work__image img {
    width: 100%;
    aspect-ratio: 1905 / 911;
    object-fit: cover;
  }

  .work__link {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
    margin-top: var(--space-xs);
  }

  .work__link:hover {
    color: var(--color-accent);
  }

  .work__image-placeholder {
    width: 100%;
    aspect-ratio: 16 / 10;
    background-color: var(--color-border);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }

  /* ------------------------------------------------
     Contact
     ------------------------------------------------ */

  .contact__content {
    max-width: 560px;
  }

  .contact__links {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

  .contact__links a {
    font-size: 0.9375rem;
    text-decoration: underline;
    text-underline-offset: 3px;
    color: var(--color-text-secondary);
  }

  .contact__links a:hover {
    color: var(--color-accent);
  }

  /* ------------------------------------------------
     Side Navigation
     ------------------------------------------------ */

  .side-nav {
    position: relative;
    opacity: 0;
    transition: opacity 0.5s ease;
    transition-delay: 0.9s;
  }

  .side-nav.is-visible {
    opacity: 1;
  }

  .side-nav__inner {
    position: sticky;
    top: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    text-align: right;
  }

  .side-nav__link {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.25rem 0;
    transition: color 0.2s ease;
  }

  .side-nav__link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  /* ------------------------------------------------
     Responsive
     ------------------------------------------------ */

  /* ------------------------------------------------
     Mobile Top Navigation
     ------------------------------------------------ */

  .mobile-nav {
    display: none;
  }

  @media (max-width: 768px) {
    .side-nav {
      display: none;
    }

    .hero__bio,
    .about__content,
    .work__description,
    .contact__content {
      max-width: 100%;
    }

    .contact__links {
      flex-direction: column;
      gap: var(--space-xs);
    }

    .mobile-nav {
      display: flex;
      position: sticky;
      top: 0;
      justify-content: space-around;
      align-items: center;
      padding: 0.75rem var(--space-sm);
      background-color: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
      z-index: 100;
    }

    .mobile-nav__link {
      font-size: 0.8125rem;
      font-weight: 600;
      color: var(--color-text-secondary);
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .mobile-nav__link:hover {
      color: var(--color-accent);
      text-decoration: none;
    }
  }

  /* ------------------------------------------------
     Scroll animations
     ------------------------------------------------ */

  .section {
    opacity: 0;
    transform: translateY(25px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .section.fade-in {
    transform: none;
  }

  .hero { transition-delay: 0s; }
  .about { transition-delay: 0.3s; }
  .work { transition-delay: 0.6s; }
  .work__entry.fade-in { transition-delay: 0.6s; }

  .section.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .animate,
  .work__entry.fade-in {
    opacity: 0;
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .animate {
    transform: translateY(25px);
  }

  .animate.is-visible,
  .work__entry.fade-in.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // Fade in hero, about, work label, and first project immediately on load
  const immediate = document.querySelectorAll('.section.fade-in, .work__entry.fade-in, .side-nav.fade-in');
  requestAnimationFrame(() => {
    immediate.forEach((el) => el.classList.add('is-visible'));
  });

  // Scroll-triggered animations for everything else
  const scrollElements = document.querySelectorAll('.section:not(.fade-in), .animate');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  scrollElements.forEach((el) => observer.observe(el));
</script>
